# Local LLM configuration used by ./start-local.sh
#
# Providers:
#   ollama   - Ollama's OpenAI-compatible local endpoint
#   lmstudio - LM Studio's OpenAI-compatible local endpoint
#   mlx      - load a Hugging Face/MLX model directly in this process

S2S_LLM_PROVIDER=ollama
S2S_LLM_MODEL=gemma4:e4b
S2S_LLM_BASE_URL=http://127.0.0.1:11434/v1
S2S_LLM_API_KEY=ollama
S2S_LLM_REASONING_EFFORT=none

# LM Studio example:
# S2S_LLM_PROVIDER=lmstudio
# S2S_LLM_MODEL=your-loaded-model-id
# S2S_LLM_BASE_URL=http://127.0.0.1:1234/v1
# S2S_LLM_API_KEY=lm-studio
# S2S_LLM_REASONING_EFFORT=none

# Native MLX example (must already exist in the Hugging Face cache):
# S2S_LLM_PROVIDER=mlx
# S2S_LLM_MODEL=unsloth/gemma-4-31b-it-UD-MLX-4bit
